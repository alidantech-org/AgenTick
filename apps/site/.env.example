# Local development uses a local SQLite/libSQL file.
DATABASE_URL=file:skillib.db

# Hosted serverless deployments use a remote libSQL/Turso URL and token.
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=...

# Use long independent random values in production.
AUTH_SECRET=replace-with-at-least-32-random-characters
SKILLIB_TOKEN_PEPPER=replace-with-another-long-random-value

# Email delivery. When RESEND_API_KEY is omitted in development, OTP and invite
# messages are printed to the server console instead.
RESEND_API_KEY=
EMAIL_FROM=Skillib <no-reply@example.com>

# Public origin used in login and organization invitation emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
