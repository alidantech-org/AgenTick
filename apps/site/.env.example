# PostgreSQL. Use a pooled URL for serverless production deployments.
DATABASE_URL=postgresql://skillib:skillib@127.0.0.1:5432/skillib
DATABASE_SSL=false
DATABASE_POOL_MAX=10
# Set false when your pooler does not support prepared statements.
DATABASE_PREPARE_STATEMENTS=true

# Use long independent random values in production.
AUTH_SECRET=replace-with-at-least-32-random-characters
SKILLIB_TOKEN_PEPPER=replace-with-another-long-random-value

# SMTP is required for OTP and organisation invitation delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me
SMTP_FROM=Skillib <no-reply@example.com>
SMTP_REPLY_TO=support@example.com
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000

# Protects the retryable outbox-dispatch route used by cron or a worker.
EVENT_DISPATCH_SECRET=replace-with-a-long-random-value

# Public origin used in login and organisation invitation emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
